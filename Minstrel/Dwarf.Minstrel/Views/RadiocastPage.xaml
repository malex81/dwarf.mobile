<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
			 xmlns:windows="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.WindowsSpecific;assembly=Microsoft.Maui.Controls"
			 xmlns:base="http://dwarf.maui.ru/base"
			 xmlns:vm="clr-namespace:Dwarf.Minstrel.ViewModels"
			 xmlns:vh="using:Dwarf.Minstrel.ViewHelpers"
             xmlns:local="using:Dwarf.Minstrel.Views"
			 x:Class="Dwarf.Minstrel.Views.RadiocastPage"
			 x:DataType="vm:RadiocastPageModel"
             Title="Интернет радио">
	<ContentPage.Resources>
		<ResourceDictionary>
			<!--<toolkit:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />-->
			<Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}" x:DataType="vm:RadioItemModel">
				<Setter Property="VerticalOptions" Value="End"/>
				<Setter Property="vh:FAIcons.RegularGlyph" Value="CirclePlay" />
				<Style.Triggers>
					<DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="false">
						<Setter Property="TextColor" Value="{toolkit:AppThemeResource ButtonTextColor}"/>
					</DataTrigger>
					<DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
						<Setter Property="vh:FAIcons.RegularGlyph" Value="CirclePause"/>
						<Setter Property="TextColor" Value="{toolkit:AppThemeResource ButtonIndicatorColor}"/>
						<Setter Property="Background" Value="{toolkit:AppThemeResource ActiveButtonBgColor}"/>
					</DataTrigger>
				</Style.Triggers>
			</Style>
			<Style x:Key="FavoriteButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}" x:DataType="vm:RadioItemModel">
				<Setter Property="VerticalOptions" Value="End"/>
				<Setter Property="HorizontalOptions" Value="End"/>
				<Setter Property="vh:FAIcons.RegularGlyph" Value="Heart" />
				<Setter Property="vh:FAIcons.SolidGlyph" Value="None" />
				<Style.Triggers>
					<DataTrigger TargetType="Button" Binding="{Binding InFavorites}" Value="false">
						<Setter Property="TextColor" Value="{toolkit:AppThemeResource ButtonTextColor}"/>
					</DataTrigger>
					<DataTrigger TargetType="Button" Binding="{Binding InFavorites}" Value="True">
						<Setter Property="vh:FAIcons.RegularGlyph" Value="None"/>
						<Setter Property="vh:FAIcons.SolidGlyph" Value="Heart"/>
						<Setter Property="TextColor" Value="{toolkit:AppThemeResource SuccessColor}"/>
						<Setter Property="Background" Value="{toolkit:AppThemeResource ActiveButtonBgColor}"/>
					</DataTrigger>
				</Style.Triggers>
			</Style>
		</ResourceDictionary>
	</ContentPage.Resources>
	<Grid RowDefinitions="auto, *">
		<local:RadiocastHeaderPanel Grid.Row="0" BindingContext="{Binding}"/>
		<RefreshView Grid.Row="1"
				windows:RefreshView.RefreshPullDirection="TopToBottom"
				IsRefreshing="{Binding IsRefreshing}"
				Command="{Binding RefreshCommand}">
			<CollectionView ItemsSource="{Binding ViewRadioList}">
				<CollectionView.ItemsLayout>
					<LinearItemsLayout Orientation="Vertical"
								   ItemSpacing="2" />
				</CollectionView.ItemsLayout>
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="vm:RadioItemModel">
						<SwipeView>
							<SwipeView.RightItems>
								<SwipeItem Text="{vh:TextSwitch OnTrue='Восстановить', OnFalse='Удалить', Value={Binding Removed}}"
									   vh:FAIcons.SolidGlyph="TrashCan"
									   Command="{Binding ToggleRemovedCommand}"
									   CommandParameter="{vh:Primitive Bool=True}"
									   BackgroundColor="{vh:ColorSwitch OnTrue={StaticResource Green}, OnFalse={StaticResource Danger}, Value={Binding Removed}}">
								</SwipeItem>
							</SwipeView.RightItems>
							<Border Style="{StaticResource BorderCard}">
								<Border.Triggers>
									<DataTrigger TargetType="Border" Binding="{Binding Removed}" Value="true">
										<Setter Property="Background" Value="{StaticResource Gray500}" />
									</DataTrigger>
								</Border.Triggers>
								<FlyoutBase.ContextFlyout>
									<MenuFlyout>
										<MenuFlyoutItem Text="Обновить"
													vh:FAIcons.SolidGlyph="RotateRight"
													Command="{Binding RefreshCommand}" />
										<MenuFlyoutItem
													Text="{vh:TextSwitch OnTrue='Восстановить', OnFalse='Удалить', Value={Binding Removed}}"
													vh:FAIcons.SolidGlyph="TrashCanArrowUp"
													vh:FAIcons.GlyphColor="{vh:ColorSwitch OnTrue={StaticResource Green}, OnFalse={StaticResource Danger}, Value={Binding Removed}}"
													Command="{Binding ToggleRemovedCommand}" />
									</MenuFlyout>
								</FlyoutBase.ContextFlyout>
								<Grid RowDefinitions="auto, *" ColumnDefinitions="auto, *">
									<Frame Grid.RowSpan="2" Padding="0">
										<!--<Image Source="{Binding Icon, Converter={StaticResource ByteArrayToImageSourceConverter}}"
												Aspect="AspectFit"
												HeightRequest="128"
												WidthRequest="128" />-->
										<Image Source="{Binding Icon}"
												Aspect="AspectFit"
												HeightRequest="128"
												WidthRequest="128" />
									</Frame>
									<VerticalStackLayout Grid.Column="1">
										<Label Style="{StaticResource SubHeadline}"
												Text="{Binding Title}"
												Padding="10, 2" />
										<Label Text="{Binding ErrorMessage}"
												TextColor="{StaticResource Danger}"
												FontSize="12"
												Padding="10, 0" />
									</VerticalStackLayout>
									<toolkit:DockLayout Grid.Column="2" Grid.Row="2" Padding="10, 0">
										<Button toolkit:DockLayout.DockPosition="Left"
												Style="{StaticResource PlayButtonStyle}"
												Command="{Binding TogglePlayingCommand}" />
										<Button toolkit:DockLayout.DockPosition="Right"
												Style="{StaticResource FavoriteButtonStyle}"
												Command="{Binding ToggleFavoritesCommand}" 
												IsVisible="{Binding Removed, Converter={toolkit:InvertedBoolConverter}}" />
										<Label Text="Удалено"
											   IsVisible="{Binding Removed}"
											   Rotation="-25"
											   Style="{StaticResource Headline}"
											   TextColor="{toolkit:AppThemeResource FgMuteColor}" />
										<Image vh:FAIcons.SolidGlyph="TowerBroadcast"
											   IsVisible="{Binding ShowLoading}"
											   vh:FAIcons.GlyphColor="{toolkit:AppThemeResource AlertColor}"
											   Style="{StaticResource IconImage}"
											   VerticalOptions="End"
											   HorizontalOptions="Start"
											   Margin="10, 0">
											<Image.Behaviors>
												<vh:AnimationBehavior>
													<vh:PulseAnimation/>
												</vh:AnimationBehavior>
											</Image.Behaviors>
										</Image>
									</toolkit:DockLayout>
								</Grid>
							</Border>
						</SwipeView>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</RefreshView>
		<toolkit:MediaElement IsVisible="False"/>
	</Grid>
</ContentPage>