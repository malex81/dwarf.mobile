<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
			 xmlns:base="http://dwarf.maui.ru/base"
			 xmlns:vm="clr-namespace:Dwarf.Minstrel.ViewModels"
			 xmlns:vh="using:Dwarf.Minstrel.ViewHelpers"
             xmlns:local="using:Dwarf.Minstrel.Views"
             x:Class="Dwarf.Minstrel.Views.RadiocastHeaderPanel"
			 x:DataType="vm:RadiocastPageModel">
	<Border
		BackgroundColor="{toolkit:AppThemeResource PanelBgColor}"
		StrokeThickness="1"
		StrokeShape="{RoundRectangle CornerRadius='0,0,8,8'}">
		<VerticalStackLayout Margin="10" Spacing="8">
			<Grid ColumnDefinitions="*, Auto">
				<local:VolumeControl Grid.Column="1" BindingContext="{Binding VolumeModel}"/>
			</Grid>
			<VerticalStackLayout>
				<SearchBar Placeholder="Поиск"
					   Text="{Binding FilterText}"
					   SearchCommand="{Binding ForceUpdateViewListCommand}"/>
				<Grid ColumnDefinitions="*, Auto">
					<Label Text="Удаленные станции"
				   TextColor="{StaticResource Danger}"
				   VerticalOptions="Center"
				   FontSize="16" />
					<Switch Grid.Column="1"
					IsToggled="{Binding FilterRemoved}" 
					VerticalOptions="Center" />
				</Grid>
			</VerticalStackLayout>
		</VerticalStackLayout>
	</Border>
	<!--
		<toolkit:DockLayout Grid.Row="0" Margin="4,2">
		<local:RadiocastHeaderPanel toolkit:DockLayout.DockPosition="Bottom" BindingContext="{Binding}"/>
		<local:VolumeControl toolkit:DockLayout.DockPosition="Right" BindingContext="{Binding VolumeModel}"/>
		<SearchBar Placeholder="Поиск"
					   Text="{Binding FilterText}"
					   SearchCommand="{Binding ForceUpdateViewListCommand}"
					   Margin="{OnIdiom Default='0,0,40,0', Desktop='0,0,10,0'}"/>
		</toolkit:DockLayout>
	-->
</ContentView>