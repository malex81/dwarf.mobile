<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
			 xmlns:vm="clr-namespace:Dwarf.Minstrel.ViewModels"
			 xmlns:vh="using:Dwarf.Minstrel.ViewHelpers"
             xmlns:local="using:Dwarf.Minstrel.Views"
             x:Class="Dwarf.Minstrel.Views.RadiocastHeaderPanel"
			 x:DataType="vm:RadiocastPageModel">
	<local:ExpandablePanel>
		<local:ExpandablePanel.StaticHeader>
			<Grid ColumnDefinitions="*, auto">
				<Grid ColumnDefinitions="auto, auto, *"
					  IsVisible="{Binding ., Converter={toolkit:IsNotNullConverter}}"
					  BindingContext="{Binding CurrentRadioItem}"
					  x:DataType="vm:RadioItemModel">
					<Border Style="{StaticResource BorderFrame}">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Command="{Binding ScrollToCommand}"/>
						</Border.GestureRecognizers>
						<Image Source="{Binding Icon}"
							   Aspect="AspectFit"
							   HeightRequest="48"
							   WidthRequest="48" />
					</Border>
					<Button Grid.Column="1"							
							Margin="16, 0"
							Style="{StaticResource IconRoundButton}"
							vh:FAIcons.RegularGlyph="CirclePlay"
							Command="{Binding TogglePlayingCommand}">
						<Button.Triggers>
							<DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="true">
								<Setter Property="vh:FAIcons.RegularGlyph" Value="CirclePause"/>
								<Setter Property="vh:FAIcons.GlyphColor" Value="{toolkit:AppThemeResource ButtonIndicatorColor}"/>
								<Setter Property="Background" Value="{toolkit:AppThemeResource ActiveButtonBgColor}"/>
							</DataTrigger>
						</Button.Triggers>
					</Button>
				</Grid>
				<local:VolumeControl Grid.Column="1" BindingContext="{Binding VolumeModel}"/>
			</Grid>
		</local:ExpandablePanel.StaticHeader>
		<local:ExpandablePanel.CollapsableContent>
			<VerticalStackLayout>
				<SearchBar Placeholder="Поиск"
						   Text="{Binding FilterText}"
						   SearchCommand="{Binding ForceUpdateViewListCommand}"/>
				<Grid ColumnDefinitions="*, Auto">
					<Label Text="Удаленные станции"
						   TextColor="{StaticResource Danger}"
						   VerticalOptions="Center" />
					<Switch Grid.Column="1"
							IsToggled="{Binding FilterRemoved}" 
							VerticalOptions="Center" />
				</Grid>
			</VerticalStackLayout>
		</local:ExpandablePanel.CollapsableContent>
	</local:ExpandablePanel>
</ContentView>